#cloud-config
autoinstall:
  version: 1
  locale: en_AU
  keyboard:
    layout: us
  early-commands:
    # otherwise packer tries to connect and exceed max attempts
    - systemctl stop ssh.service
    - systemctl stop ssh.socket
  network:
    version: 2
    ethernets:
      eth0:
        dhcp4: true
  storage:
    layout:
      name: direct
      ptable: msdos
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDrBPobebA5Bn6b2jW6OxeZqbi9F1l5GyDsokDHzJ745 packer
  user-data:
    disable_root: false
  apt:
    mirror-selection:
      primary:
        - uri: "http://mirror.aarnet.edu.au/ubuntu"
  late-commands:
    - sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /target/etc/ssh/sshd_config
    - sed -ie 's/GRUB_CMDLINE_LINUX=.*/GRUB_CMDLINE_LINUX="console=tty0 console=ttyS0,115200n8 vga=788 consoleblank=0 net.ifnames=0 systemd.log_color=no"/' /target/etc/default/grub
    - curtin in-target --target /target -- update-grub2
